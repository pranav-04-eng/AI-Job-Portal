# Copy to backend/.env and fill in. All services load this same file.

# Required — Groq API key (STT, LLM, TTS). Get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Shared JWT signing secret. Tokens minted by auth-service are verified by the
# other services, so this MUST be identical across them (it is — one .env).
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=720

# Resume-screening gate: applications scoring below this are auto-rejected and
# never reach the voice interview.
SCREEN_PASS_THRESHOLD=60

# Frontend origin allowed through the gateway's CORS.
FRONTEND_ORIGIN=http://localhost:5173

# Service URLs (defaults work for local dev; services run on 90xx to avoid
# colliding with other local stacks on 80xx). Override only if you move them.
# AUTH_URL=http://localhost:9001
# JOBS_URL=http://localhost:9002
# SCREENING_URL=http://localhost:9003
# INTERVIEW_URL=http://localhost:9004
